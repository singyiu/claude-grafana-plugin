// claude-grafana :: paste this block into your existing /etc/alloy/config.alloy
// if you chose --mode=skip during /grafana-setup. The setup script normally
// inserts this fenced section automatically and re-renders it on re-run.
//
// Required env vars (set via /etc/alloy/claude.env, sourced by a systemd
// drop-in that the plugin installs):
//   GRAFANA_CLOUD_OTLP_ENDPOINT
//   GRAFANA_CLOUD_OTLP_INSTANCE_ID
//   GRAFANA_CLOUD_OTLP_API_TOKEN

// >>> claude-grafana managed BEGIN — do not edit by hand
otelcol.receiver.otlp "claude_code" {
  grpc { endpoint = "127.0.0.1:4317" }
  http { endpoint = "127.0.0.1:4318" }
  output {
    metrics = [otelcol.processor.deltatocumulative.claude_grafana.input]
    logs    = [otelcol.processor.batch.claude_grafana.input]
  }
}

// Convert delta-temporality counters (Claude Code default) to cumulative,
// required by Grafana Cloud / Mimir. Without this, metrics fail with HTTP 400.
otelcol.processor.deltatocumulative "claude_grafana" {
  output {
    metrics = [otelcol.processor.batch.claude_grafana.input]
  }
}

otelcol.processor.batch "claude_grafana" {
  output {
    metrics = [otelcol.exporter.otlphttp.claude_grafana.input]
    logs    = [otelcol.exporter.otlphttp.claude_grafana.input]
  }
}

otelcol.exporter.otlphttp "claude_grafana" {
  client {
    endpoint = sys.env("GRAFANA_CLOUD_OTLP_ENDPOINT")
    auth     = otelcol.auth.basic.claude_grafana.handler
  }
}

otelcol.auth.basic "claude_grafana" {
  username = sys.env("GRAFANA_CLOUD_OTLP_INSTANCE_ID")
  password = sys.env("GRAFANA_CLOUD_OTLP_API_TOKEN")
}
// <<< claude-grafana managed END
