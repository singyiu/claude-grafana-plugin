// claude.alloy — receives Claude Code OTLP traffic and exports to Grafana Cloud.
//
// Generated by claude-grafana plugin v{{VERSION}}. Do not hand-edit this file.
// Re-run /grafana-setup or scripts/03-configure-alloy.sh to regenerate.
//
// Required env (read from EnvironmentFile drop-in):
//   GRAFANA_CLOUD_OTLP_ENDPOINT      e.g. https://otlp-gateway-prod-us-central-0.grafana.net/otlp
//   GRAFANA_CLOUD_OTLP_INSTANCE_ID   numeric instance ID, used as basic-auth username
//   GRAFANA_CLOUD_OTLP_API_TOKEN     access-policy token, used as basic-auth password

logging {
  level  = "info"
  format = "logfmt"
}

// Local OTLP receiver — Claude Code talks to this on 127.0.0.1.
otelcol.receiver.otlp "claude_code" {
  grpc {
    endpoint = "127.0.0.1:4317"
  }
  http {
    endpoint = "127.0.0.1:4318"
  }

  output {
    metrics = [otelcol.processor.batch.claude.input]
    logs    = [otelcol.processor.batch.claude.input]
  }
}

// Batch and add a service.namespace tag to make queries easier.
otelcol.processor.attributes "claude" {
  action {
    key    = "service.namespace"
    value  = "claude-code"
    action = "insert"
  }

  output {
    metrics = [otelcol.processor.batch.claude.input]
    logs    = [otelcol.processor.batch.claude.input]
  }
}

otelcol.processor.batch "claude" {
  output {
    metrics = [otelcol.exporter.otlphttp.grafana_cloud.input]
    logs    = [otelcol.exporter.otlphttp.grafana_cloud.input]
  }
}

// Forward to Grafana Cloud OTLP gateway with Basic auth.
otelcol.exporter.otlphttp "grafana_cloud" {
  client {
    endpoint = sys.env("GRAFANA_CLOUD_OTLP_ENDPOINT")
    auth     = otelcol.auth.basic.grafana_cloud.handler
  }
}

otelcol.auth.basic "grafana_cloud" {
  username = sys.env("GRAFANA_CLOUD_OTLP_INSTANCE_ID")
  password = sys.env("GRAFANA_CLOUD_OTLP_API_TOKEN")
}
