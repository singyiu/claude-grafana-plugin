# Copy to .env and fill in. The setup skill (`/grafana-setup`) writes this for you.
# .env is gitignored. Never commit real values.

# ─── Grafana Cloud OTLP gateway (Alloy → Cloud) ──────────────────────────────
# From: https://grafana.com/orgs/<your-org>/stacks
# Stack -> "Send Data" -> "OpenTelemetry" tile -> shows endpoint + instance ID.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-central-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_INSTANCE_ID=000000

# Access policy token with scopes: metrics:write, logs:write
# Create at: https://grafana.com/orgs/<your-org>/access-policies
GRAFANA_CLOUD_OTLP_API_TOKEN=glc_eyJ...replace-me...

# ─── Grafana Cloud HTTP API (skills query / dashboard) ───────────────────────
# Your stack URL — what you see when you log in. Example: https://my-org.grafana.net
GRAFANA_CLOUD_STACK_URL=https://your-stack.grafana.net

# Service-account or admin token with scopes: dashboards:write, datasources:read
# Different from the OTLP token above (different scopes).
GRAFANA_CLOUD_API_TOKEN=glsa_...replace-me...

# Optional: pre-resolved datasource UIDs (the plugin auto-discovers if blank)
GRAFANA_CLOUD_PROM_DATASOURCE_UID=
GRAFANA_CLOUD_LOKI_DATASOURCE_UID=

# Optional: dashboards folder UID (auto-creates "claude-grafana" folder if blank)
GRAFANA_CLOUD_DASHBOARD_FOLDER_UID=
